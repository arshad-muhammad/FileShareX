{
  "name": "filesharex-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "website",
    "desktop"
  ],
  "scripts": {
    "web:dev": "npm --prefix website run dev",
    "web:build": "npm --prefix website run build",
    "web:start": "npm --prefix website run start",
    "electron:start": "npm --prefix desktop run start",
    "electron:pack": "npm --prefix desktop run pack",
    "electron:dist": "npm --prefix desktop run dist",
    "mobile:init": "npx cap init",
    "mobile:add": "npx cap add android",
    "mobile:sync": "npx cap sync",
    "mobile:build": "npm run web:build && npx cap sync && cd android && gradlew assembleDebug"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
